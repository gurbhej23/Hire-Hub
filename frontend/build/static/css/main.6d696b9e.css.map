.password-reset-page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24px;
  background:
    radial-gradient(circle at top left, rgba(47, 93, 80, 0.12), transparent 28%),
    radial-gradient(circle at bottom right, rgba(92, 117, 103, 0.14), transparent 24%),
    linear-gradient(135deg, #faf9f6 0%, #f3f1eb 48%, #f8f7f3 100%);
}

.password-reset-shell {
  width: min(100%, 440px);
  padding: 32px 30px;
  border-radius: 28px;
  border: 1px solid rgba(148, 163, 184, 0.2);
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 26px 60px rgba(15, 23, 42, 0.12);
  backdrop-filter: blur(12px);
}

.password-reset-badge {
  display: inline-flex;
  align-items: center;
  padding: 8px 14px;
  border-radius: 999px;
  background: #ecefe8;
  color: #2f5d50;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.password-reset-title {
  margin: 18px 0 8px;
  color: #0f172a;
  font-size: 32px;
  line-height: 1.1;
  letter-spacing: -0.03em;
}

.password-reset-copy {
  margin: 0 0 24px;
  color: #64748b;
  font-size: 15px;
  line-height: 1.7;
}

.password-reset-form {
  display: grid;
  gap: 14px;
}

.password-reset-input {
  width: 100%;
  box-sizing: border-box;
  padding: 15px 16px;
  border: 1px solid #dbe4f0;
  border-radius: 14px;
  background: #f6f5f2;
  color: #0f172a;
  font-size: 15px;
  transition:
    border-color 0.2s ease,
    box-shadow 0.2s ease,
    background 0.2s ease;
}

.password-reset-input:focus {
  outline: none;
  border-color: #2f5d50;
  background: #ffffff;
  box-shadow: 0 0 0 4px rgba(47, 93, 80, 0.12);
}

.password-reset-input::placeholder {
  color: #94a3b8;
}

.password-reset-button {
  border: none;
  border-radius: 14px;
  padding: 14px 18px;
  background: linear-gradient(135deg, #18211d, #2f5d50);
  color: #ffffff;
  font-size: 15px;
  font-weight: 700;
  cursor: pointer;
  transition: transform 0.18s ease, box-shadow 0.18s ease, filter 0.18s ease;
}

.password-reset-button:hover {
  transform: translateY(-1px);
  box-shadow: 0 18px 34px rgba(47, 93, 80, 0.2);
  filter: saturate(1.05);
}

@media (max-width: 640px) {
  .password-reset-page {
    padding: 16px;
  }

  .password-reset-shell {
    padding: 24px 20px;
    border-radius: 22px;
  }

  .password-reset-title {
    font-size: 28px;
  }
}
